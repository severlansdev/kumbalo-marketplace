{
  "version": 2,
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" },
    { "src": "frontend/**", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/(css|js|assets|images|ico|svg|assets)/(.*)", "destination": "/frontend/$1/$2" },
    { "source": "/((?!api/|css/|js/|assets/|images/).*)", "destination": "/frontend/index.html" }
  ]
}
