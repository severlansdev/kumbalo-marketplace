{
  "version": 2,
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" },
    { "src": "frontend/**", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/((?!api/).*\\.[a-z0-9]+)$", "destination": "/frontend/$1" },
    { "source": "/((?!api/).*)", "destination": "/frontend/index.html" }
  ]
}
