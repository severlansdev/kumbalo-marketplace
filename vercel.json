{
  "version": 2,
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" },
    { "src": "frontend/**", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/(css|js|assets|images|ico|svg)/(.*)", "destination": "/frontend/$1/$2" },
    { "source": "/(.*\\.(html|svg|png|jpg|jpeg|webp))$", "destination": "/frontend/$1" },
    { "source": "/(.*)", "destination": "/frontend/index.html" }
  ]
}
