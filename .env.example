# ==========================================
# KUMBALO FINTECH ECOSISTEMA - VARIABLES DE ENTORNO
# ==========================================

# 1. Base de Datos (Producción: Neon / Supabase / AWS RDS)
DATABASE_URL=postgresql://user:password@hostname:5432/dbname

# 2. Secretos de Seguridad (Autenticación e Integridad)
JWT_SECRET=reemplazar_con_key_aleatoria_super_cifrada_256bits
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440 # 24 Horas

# 3. AWS S3 (Almacenamiento de Fotos e Imágenes HD)
AWS_ACCESS_KEY_ID=tu_aws_key
AWS_SECRET_ACCESS_KEY=tu_aws_secret
S3_BUCKET_NAME=kumbalo-media-prod
AWS_REGION=us-east-1

# 4. MercadoPago (Webhooks y Escrow Transaccional)
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxx-xxxxxx-xxxx-xxxxxxxx
MERCADOPAGO_WEBHOOK_SECRET=tu_secreto_webhook

# 5. SMTP / Transaccional Email (SendGrid / Resend / AWS SES)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=soporte@kumbalo.com
SMTP_PASS=tu_app_password_o_llave_api
