# Configuración de Base de Datos
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=marketplace
DATABASE_URL=postgresql://postgres:your_strong_password_here@db:5432/marketplace

# Configuración JWT Token
JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# AWS S3
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=kumbalo-motos-imagenes

# Grafana
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Sentry (Error Tracking)
SENTRY_DSN=

# Email (SendGrid/AWS SES)
EMAIL_API_KEY=
EMAIL_FROM=noreply@kumbalo.com

# Fintech - MercadoPago (Credenciales de Prueba)
MERCADOPAGO_ACCESS_TOKEN=APP_USR-YOUR-MERCADOPAGO-ACCESS-TOKEN

# URLs de Entorno (Importante para Producción)
FRONTEND_URL=https://kumbalo-marketplace.vercel.app
BACKEND_URL=https://kumbalo-api.vercel.app

# Correo (Real SMTP fallback)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=no-reply@kumbalo.com
SMTP_PASSWORD=tupasswordaqui
